# Server-only source and optional AI keys. Never prefix these with NEXT_PUBLIC_.
NPS_API_KEY=
ANTHROPIC_API_KEY=

# Optional grounded Trail Guide retrieval. All values are server-only. The
# embedding URL should point to the private CPU service in services/rag-embedder.
RAG_ENABLED=false
RAG_EMBEDDING_URL=http://127.0.0.1:8010
RAG_EMBEDDING_TOKEN=
RAG_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
RAG_RETRIEVAL_LIMIT=8
RAG_SOURCE_MANIFEST=docs/rag-sources.json

# Optional switchable OpenStreetMap-compatible search endpoints. The defaults
# are appropriate only for low-volume, user-triggered beta searches.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
OVERPASS_BASE_URL=https://overpass-api.de/api/interpreter

# Optional hosted MapLibre style overrides. Local development defaults to the
# light and dark Stadia Alidade Smooth styles and needs no key. Production must
# use Stadia domain authentication and a commercial plan; these URLs are public
# configuration, never secrets. MAP_STYLE_URL remains a shared fallback.
NEXT_PUBLIC_MAP_STYLE_URL=
NEXT_PUBLIC_MAP_STYLE_LIGHT_URL=
NEXT_PUBLIC_MAP_STYLE_DARK_URL=

# Authentication and persistence.
DATABASE_URL=
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
