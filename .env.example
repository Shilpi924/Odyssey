# Server-only source and optional AI keys. Never prefix these with NEXT_PUBLIC_.
NPS_API_KEY=
ANTHROPIC_API_KEY=

# Optional hosted MapLibre style override. Local development defaults to Stadia
# Maps and needs no key. Production must use Stadia domain authentication and a
# commercial plan; this URL is public configuration, never a secret.
NEXT_PUBLIC_MAP_STYLE_URL=

# Authentication and persistence.
DATABASE_URL=
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
